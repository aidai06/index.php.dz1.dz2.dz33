<?php

if ($_SERVER['REQUEST_METHOD'] == 'POST') {

    if (!empty($_POST['name'])) {
        echo "Имя: " . $_POST['name'] . "<br>";
    } else {
        echo "Имя не заполнено<br>";
    }

    if (!empty($_POST['email'])) {
        echo "Email: " . $_POST['email'] . "<br>";
