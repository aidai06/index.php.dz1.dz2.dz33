    // $str -- строка, $start -- откуда начинаем, $length -- сколько символов берем (если не указано -- до самого конца)
    function my_substr($str,$start,$length = null) 
    {
        $result =''; // открываем пустую строку, потому что результат будет сохраняться именно сюда
        
        if($length === null) // длина не указана, значит берем строку от начала и до самого конца
            {
                // $i = $start -- начинает отсюда, isset($str[$i]) -- проверяет, есть ли символ, $i++ -- переходит к следующему символу
                for($i =$start; isset($str[$i]);$i++)
                    {
                        $result.=$i.'-'.$str[$i].'<br>';
                    }
            }else {
                for($i=$start;isset($str[$i]);$i++) {
                    $result.=$i.'-'.$str[$i].'<br>';
                }
            }
            return $result;
    }

    function my_substr1($str, $start, $length)
    {
        $result = '';
      
            for ($i = $start; isset($str[$i]) && $i < $start + $length; $i++) {
                $result .= $i.' - '.$str[$i].'<br>';;
            }
        
        return $result;
    }

    function my_substr2($str, $start, $length)
    {
        $result = "";
        $str_len = 0;

        // считает общую длину строки
        while (isset($str[$str_len])) { 
            $str_len++;
        }

        if ($length < 0) {
            $length = $str_len - $start + $length;
        }

        for ($i = $start; $i < $start + $length; $i++) {
            if (!isset($str[$i])) break;
            $result .= $str[$i];
        }
        return $result;
    }
    echo my_substr2('Hello world!', 9, -1);
    echo '<br>';

    // считает, сколько раз $substr встречается внутри $str
    function my_substr_count($str, $substr) 
    {
        $count = 0; // считает, сколько раз встретилось
        
        // $i = 0 → начинает с самого начала
        // isset($str[$i]) → проверяет, есть ли символ
        // $i++ → переходит к следующему символу, проверяет каждую позицию
        for ($i = 0; isset($str[$i]); $i++) {
            
            // Внутри строки $str:
            // берет кусочек, начиная с позиции $i
            // длиной с размер искомого $substr
            // и проверяет: равен ли этот кусочек нашему $substr?
            if (my_substr2($str, $i, my_strlen1($substr)) === $substr) {
                $count++; 
            }
        }
        return $count;
    }

    /*
     * Напишите функцию no_space(string $str): string, которая принимает 
     * аргументом строку и возвращает строку с удаленными пробелами
     * */

    function no_space(string $str): string
    {
        return str_replace(' ', '', $str);
    }

