    function my_srtlen($str)
    {
        $count = 0;
        while(isset($str[$count])) 
            {
                $count++;
            }
            return $count;
    }

    echo my_srtlen('hello Aiymkan');
    echo '<br>';

    function my_strlen1($str)
    {
        $count = 0;
        // $i = 0 -- это знак, что мы начинаем с самого первого символа строки
        // isset($str[$i]) -- это проверяльщик, он смотрит: есть ли вообще такой символ?
        // Если символ есть, то цикл продолжает свою работу.
        // Если символа больше нет, то он останавливает работу.
        // $i++ -- увеличиваем индекс на 1, идем к следующему символу.
        // То есть, если нужный символ нашелся, мы идем искать дальше и всё складывается дальше.
        for($i = 0; isset($str[$i]); $i++) 
            {
                $count++; // а это просто считает количество этих символов
            }
            return $count;
    }

    echo my_strlen1('Hello world  my name Aiymkan!');
    echo '<br>';
    // здесь 4 означает "начни считать отсюда", а -2 означает "отними столько-то с конца"
    echo substr('Hello world', 4, -2); 
